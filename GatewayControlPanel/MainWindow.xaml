<Window x:Class="GatewayControlPanel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="API Gateway Control Panel" Height="400" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="🚀 API Gateway Control Panel"
                   FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Port Selection -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Port:" VerticalAlignment="Center" Width="80" FontSize="14"/>
            <TextBox x:Name="PortTextBox" Width="100" Height="30"
                     Text="8887" FontSize="14" VerticalContentAlignment="Center"/>
            <TextBlock Text="(Default: 8887)" VerticalAlignment="Center"
                       Margin="10,0,0,0" Foreground="Gray"/>
        </StackPanel>

        <!-- Gateway Selection -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Gateway:" VerticalAlignment="Center" Width="80" FontSize="14"/>
            <ComboBox x:Name="GatewayTypeComboBox" Width="200" Height="30"
                      FontSize="14" SelectedIndex="0">
                <ComboBoxItem Content="Node.js (Recommended)"/>
                <ComboBoxItem Content="Go (Fastest)"/>
                <ComboBoxItem Content=".NET 8 (Windows 2016+)"/>
            </ComboBox>
        </StackPanel>

        <!-- Control Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,20">
            <Button x:Name="StartButton" Content="▶ Start Gateway"
                    Width="150" Height="40" FontSize="14" FontWeight="Bold"
                    Background="#4CAF50" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="StartButton_Click" Margin="0,0,10,0"/>
            <Button x:Name="StopButton" Content="⏹ Stop Gateway"
                    Width="150" Height="40" FontSize="14" FontWeight="Bold"
                    Background="#F44336" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="StopButton_Click" IsEnabled="False" Margin="0,0,10,0"/>
            <Button x:Name="OpenAdminButton" Content="🌐 Open Admin UI"
                    Width="150" Height="40" FontSize="14" FontWeight="Bold"
                    Background="#2196F3" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="OpenAdminButton_Click" IsEnabled="False"/>
        </StackPanel>

        <!-- Status Display -->
        <Border Grid.Row="4" BorderBrush="#CCCCCC" BorderThickness="1"
                Background="#F5F5F5" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="StatusTextBlock"
                           Text="Ready to start gateway..."
                           FontFamily="Consolas" FontSize="12"
                           TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,15,0,0">
            <TextBlock x:Name="StatusLabel" Text="● Stopped"
                       Foreground="Red" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="0,0,20,0"/>
            <TextBlock Text="Admin UI: http://localhost:8888"
                       Foreground="Gray" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
